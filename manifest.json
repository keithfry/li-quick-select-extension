{
  "manifest_version": 3,
  "name": "LinkedIn Job Quick Select",
  "version": "1.2",
  "description": "Quickly select 'About the job' section on LinkedIn with a customizable keyboard shortcut",
  "permissions": ["storage", "windows", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Job Quick Select"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["storage.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
