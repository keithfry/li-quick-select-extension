{
  "name": "jd-grab",
  "version": "1.8.6",
  "description": "Chrome extension to quickly select job descriptions on LinkedIn, Indeed, Glassdoor, Wellfound, Welcome to the Jungle, Greenhouse, Lever, Ashby, ZipRecruiter, and We Work Remotely with customizable keyboard shortcuts",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:e2e": "playwright test tests/e2e",
    "test:unit": "playwright test tests/unit",
    "test:integration": "playwright test tests/integration",
    "test:report": "playwright show-report",
    "screenshots": "node scripts/generate-screenshots.mjs",
    "promo-tiles": "node scripts/generate-promo-tiles.mjs",
    "build": "./build.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/chrome": "^0.0.253"
  },
  "author": "",
  "license": "MIT"
}
